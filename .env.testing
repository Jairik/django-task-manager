# Purposefully left local/testing PostgreSQL credentials used by setup and development.
# Source this file before running Django: set -a && source .env.testing && set +a

# Database name Django will connect to (create it first with `createdb task_manager - done in setup.sh`).
POSTGRES_DB=task_manager
# PostgreSQL role with access to the database above.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Host and port where PostgreSQL is listening.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
